# .env.example
# Copy to .env and modify as needed.
# All values here are the defaults — only set what you want to override.

# Embedding model (change to all-mpnet-base-v2 for higher quality)
# EMBEDDING_MODEL=all-MiniLM-L12-v2

# Number of results returned per query
# TOP_K_RESULTS=5

# Cache similarity threshold (0.0 - 1.0)
# Lower = more hits, less precise. Higher = fewer hits, more precise.
# See experiments/threshold_analysis.ipynb for full analysis.
# CACHE_THRESHOLD=0.85

# UMAP reduction dimensions for clustering
# UMAP_N_COMPONENTS=50

# Cluster count search range
# CLUSTER_K_MIN=10
# CLUSTER_K_MAX=31
# CLUSTER_K_STEP=5
